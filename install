# load config
SCRIPT_DIR="$(cd -- "$(dirname -- "$0")" && pwd)"
source "$SCRIPT_DIR/paths.conf"

# waybar conf copy
cp ui/waybar/config-$WAYBARCONFIG/config.jsonc ~/.config/waybar/
cp ui/waybar/config-$WAYBARCONFIG/style.css ~/.config/waybar/
killall waybar
waybar & disown


# obsidian config copy
cp -r ui/obsidian/.obsidian "$VAULT_PATH"
