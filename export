# script to copy from repo to config location

# load paths
SCRIPT_DIR="$(cd -- "$(dirname -- "$0")" && pwd)"
source "$SCRIPT_DIR/paths.conf"

# keyd conf
sudo cp -rf "$SCRIPT_DIR/system/keyd" /etc/

# waybar conf
cp -r "$SCRIPT_DIR/ui/waybar/config-$WAYBARCONFIG/"* ~/.config/waybar/

# obsidian config copy
cp -r "$SCRIPT_DIR/ui/obsidian/.obsidian" "$VAULT_PATH"

# hyprland config
cp -r "$SCRIPT_DIR/system/hypr/" ~/.config/

# ghossty config
cp -r "$SCRIPT_DIR/ui/ghostty/"* ~/.config/ghostty/
